# CoinGecko — used by lib/coingecko.ts for every CoinGecko request site-wide.
# Get a key at https://www.coingecko.com/en/api
# Never commit real keys. Copy to .env.local for local/dev.

COINGECKO_API_KEY=
# "demo" (default, free Demo API) or "pro" (paid Pro API host + header)
COINGECKO_API_PLAN=demo
